    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.4.1",
    "drizzle-orm": "catalog:",
    "exifr": "^7.1.3",
    "express": "^5",
    "imghash": "^1.1.0",
    "jose": "^6.0.10",
    "pino": "^9",
    "pino-http": "^10",
    "sharp": "^0.34.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.14",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
