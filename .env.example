# Copy to ".env" in the repo root (do not commit .env).
# Start DB: pnpm run db:up
# Apply schema: pnpm run db:push
# Demo data: pnpm run db:seed

DATABASE_URL=postgresql://civicai:civicai@127.0.0.1:5432/civicai

# Required for JWT auth (use a long random string in production)
JWT_SECRET=dev-change-this-to-a-long-random-secret

# Optional: provision authority accounts via POST /api/admin/authorities
ADMIN_PROVISION_KEY=dev-admin-provision-key

# OTP codes also appear in API logs; set to "false" to omit the duplicate line
LOG_OTP_TO_CONSOLE=true

# API server (when running `pnpm run api:dev` from repo root with this file as `.env`)
PORT=3000

# Frontend (Vite loads `.env` from `artifacts/civicai/` — copy these there if you use a file)
# PORT=5173
# BASE_PATH=/
# API_PROXY_TARGET=http://127.0.0.1:3000

# Optional: OpenAI vision for issue classification
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini

# Optional: Nominatim user-agent (polite usage)
# NOMINATIM_USER_AGENT=CivicAI/1.0 (your contact URL or email)
